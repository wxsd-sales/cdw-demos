# Vidcast public playlist UUID (same default as vidcast-macro.js).
VIDCAST_PLAYLIST_ID=19aea050-4da1-4ed7-a4a1-84d64dd76b43

# Webex OAuth (same client for every slot). Comma-separated REFRESH_TOKEN and USERLIST must
# have the same number of entries (slot i uses USERLIST[i] with REFRESH_TOKEN[i]).
# POST /command start matches body.user to USERLIST (trim, case-insensitive).
# Rotated refresh_token values are kept in process memory only.
WEBEX_CLIENT_ID=
WEBEX_CLIENT_SECRET=
REFRESH_TOKEN=
USERLIST=
# Optional
# PORT=3040

# Docker: copy this file to `.env` before `docker build` — the Dockerfile COPYs `.env` into the
# image so you do not need `-e VIDCAST_PLAYLIST_ID=...` on `docker run`.
